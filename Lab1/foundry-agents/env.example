############################################
# Required Variables for Agent Deployment
############################################
AZURE_SUBSCRIPTION_ID="11111111-2222-3333-4444-555555555555"
RESOURCE_GROUP="rg-ai-foundry-standard"
LOCATION="eastus2"

AZURE_EXISTING_AIPROJECT_ENDPOINT="https://ai-foundry-std-ai-foundry.services.ai.azure.com/api/projects/project-1"
AZURE_AI_PROJECT_NAME="ai-foundry-std-ai-foundry"
AZURE_AI_AGENT_DEPLOYMENT_NAME="gpt-4.1"
AZURE_SEARCH_ENDPOINT="https://public-this-ai-foundry-ai-search-xxxxx.search.windows.net"
AZURE_STORAGE_ACCOUNT_URL="https://publicthisfndryxxxxx.blob.core.windows.net"
AZURE_TABLES_ACCOUNT_URL="https://publicthisfndryxxxxx.table.core.windows.net"

AZURE_OPENAI_API_VERSION="2023-05-15"
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-large"
AZURE_OPENAI_ENDPOINT="https://ai-foundry-std-ai-foundry.cognitiveservices.azure.com/openai/deployments/text-embedding-3-large/embeddings?api-version=2023-05-15"
AZURE_OPENAI_ENDPOINT2="https://ai-foundry-std-ai-foundry.openai.azure.com/"
AZURE_SEARCH_INDEX="public-this-ai-foundry-ai-search-xxxxx"
AZURE_STORAGE_ACCOUNT_NAME="publicthisfndryxxxxx"
AZURE_OPENAI_EMBED_DIM="3072"

# SCF (Secure Controls Framework) Search Index
# Azure AI Search index name containing SCF security controls and compliance data
SCF_AZURE_SEARCH_INDEX="central"

AZURE_INDEXING_FUNCTION_URL="https://indexer.xxxxx-yyyyy.eastus2.azurecontainerapps.io/api/index"
AZURE_SEARCH_SEMANTIC_CONFIG="DefaultSemantic"

OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT="true"

############################################
# Optional Variables
############################################
LOG_LEVEL="DEBUG" # Could be DEBUG", "WARNING", "ERROR", "CRITICAL or "INFO"(which is the default is none is specified), "
LOG_File="insights-agent.log"
APP_VERBOSE="1"

############################################
# MCP (Model Context Protocol) Integration
############################################
# Comma-separated list of allowed MCP servers/tools the agent may load.
# Example: azurepricing,microsoft-learn,github,azuredevops
MCP_ALLOWED_SERVERS="azurepricing,microsoft_learn"

# Azure Pricing MCP Server (local/self-hosted)
AZURE_PRICING_MCP_URL="https://azure-pricing-mcp.xxxxx-yyyyy.eastus2.azurecontainerapps.io/sse"

# Microsoft Learn MCP Server (remote - official Microsoft server)
# Official Microsoft Learn documentation MCP server for Azure best practices and Well-Architected Framework
MICROSOFT_LEARN_MCP_URL="https://learn.microsoft.com/api/mcp"

# Other MCP servers
AZURE_DEVOPS_MCP_URL=""

# MCP Server Configuration
MCP_HOST="0.0.0.0"
MCP_PORT="8080"
MCP_DEBUG="true"
MCP_RELOAD="true"
CORS_ORIGINS="*"

